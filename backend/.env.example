# Backend Environment Variables
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres.railway.internal:5432/railway
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=30d
PORT=3000
NODE_ENV=production

# Comma-separated allowlist for browser origins.
# Example: https://web-bm0r5s56u-alandsurchi456-gmailcoms-projects.vercel.app,https://yourdomain.com
CORS_ORIGINS=
